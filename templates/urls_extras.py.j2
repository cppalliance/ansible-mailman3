# {{ ansible_managed }}
#
# Additive URL overlay for Mailman-web.
#
# This module inherits urlpatterns from whichever base URLconf is currently
# active (the role's custom-roots module if postorius/hyperkitty prefixes were
# overridden, otherwise upstream mailman_web.urls) and prepends any extras
# opted in through role variables. Prepending ensures our patterns win on both
# URL resolution (first match) and reverse-by-name lookups.
#
# Installed by ansible-mailman3 when at least one of the extras below is
# enabled. If none are enabled, the role points ROOT_URLCONF at the base
# module directly and this file is not installed.

from django.urls import path, reverse_lazy
from django.views.generic import RedirectView

{% if mailman3_postorius_root is defined or mailman3_hyperkitty_root is defined %}
# Custom postorius/hyperkitty roots are in play -> inherit from the role's
# base URLconf (installed alongside this one).
from ansible_galaxyproject_mailman3_urls import urlpatterns as _base_urlpatterns
{% else %}
# No custom roots configured -> inherit directly from upstream mailman_web.
from mailman_web.urls import urlpatterns as _base_urlpatterns
{% endif %}

_extras = []

{% if mailman3_socialaccount_auto_login_url | default('') | trim | length > 0 %}
# ---------------------------------------------------------------------------
# Auto-redirect /accounts/login/ to a single social provider.
#
# SOCIALACCOUNT_ONLY = True is an enforcement setting - it doesn't touch
# allauth's account/login.html template, so by default the chooser page still
# renders a local-password form (POSTs to which would 403) alongside a
# "Sign in with X" button. When only one provider is meaningful on this
# deployment, we can skip the chooser entirely by replacing /accounts/login/
# with a redirect to that provider's login URL.
#
# Requires SOCIALACCOUNT_LOGIN_ON_GET = True (otherwise the provider URL
# renders its own "click to continue" page instead of starting OAuth/OIDC on
# GET, which just moves the extra click to a different template).
#
# NOTE on URL-name reversal: this pattern shares the name 'account_login' with
# allauth's own pattern. Because we prepend, ours is registered first, so
# reverse('account_login') resolves to our pattern - which still points at
# /accounts/login/ (same path allauth registered), so no functional change to
# any {% raw %}{% url 'account_login' %}{% endraw %} rendered in templates. The URL resolver still
# matches ours first for actual /accounts/login/ requests, which is what makes
# the redirect take effect.
# ---------------------------------------------------------------------------
_extras.append(
    path(
        "accounts/login/",
        RedirectView.as_view(
            url="{{ mailman3_socialaccount_auto_login_url | trim }}",
            permanent=False,
            query_string=True,
        ),
        name="account_login",
    ),
)
{% endif %}

{% if mailman3_socialaccount_signup_stub | default(false) | bool %}
# ---------------------------------------------------------------------------
# Stubs for URL names that django-allauth removes when SOCIALACCOUNT_ONLY=True.
#
# Several installed templates (allauth's own account/login.html, postorius
# and django-mailman3 navbar/base templates) reverse these names unconditionally
# and would raise NoReverseMatch on any page render. Each stub registers the
# name so reverse() succeeds, and redirects the URL to the login page (which
# is where SSO happens) preserving any query string like ?next=...
#
# Add more names to _socialaccount_only_stubs below as they surface.
# ---------------------------------------------------------------------------
_socialaccount_only_stubs = [
    # (URL path, URL name)
    ("accounts/signup/",         "account_signup"),
    ("accounts/password/reset/", "account_reset_password"),
]

for _path, _name in _socialaccount_only_stubs:
    _extras.append(
        path(
            _path,
            RedirectView.as_view(
                url=reverse_lazy("account_login"),
                permanent=False,
                query_string=True,
            ),
            name=_name,
        ),
    )
{% endif %}

urlpatterns = _extras + _base_urlpatterns
